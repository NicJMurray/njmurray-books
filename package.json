    "import:goodreads": "node scripts/refresh-goodreads.mjs --csv data/goodreads_library_export.csv"
  },
  "dependencies": {
    "csv-parse": "^5.6.0",
    "fast-xml-parser": "^5.3.2",
    "lucide-react": "^0.468.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "vite": "^8.0.16",
    "wrangler": "^4.103.0"
  }
}
