{
  "name": "njmurray-books",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "worker:dev": "wrangler dev",
    "deploy": "npm run build && wrangler deploy",
